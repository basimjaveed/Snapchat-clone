{
  "expo": {
    "name": "SnapClone",
    "slug": "snapchat-clone",
    "version": "1.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "dark",
    "scheme": "snapclone",
    "sdkVersion": "54.0.0",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.snapclone.app"
    },
    "android": {
      "package": "com.snapclone.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "static"
    },
    "plugins": [
      "expo-router",
      "expo-secure-store",
      [
        "expo-camera",
        {
          "cameraPermission": "Allow SnapClone to access your camera to send snaps."
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Allow SnapClone to access your photos."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "cee19259-0980-4857-806b-6c6386590839"
      }
    }
  }
}
